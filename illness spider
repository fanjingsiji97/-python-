def clean_dirname(name):
    """使字符串能安全用作 Windows 文件夹名"""
    if not isinstance(name, str):
        name = str(name)
    name = name.strip()
    # 替换非法字符
    name = re.sub(r'[\\/*?:"<>|]', '_', name)
    # 删除末尾的点和空格（Windows 不允许）
    name = name.rstrip('. ')
    # 避免空名
    return name or "未命名"
