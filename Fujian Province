def build_trade_payload(page_no: int = 1, page_size: int = 20, kind: str = "GCJS", ggtype: str = "1", days_ago: int = 30):
    # 结束时间：当前时刻
    end_time = datetime.now()
    # 开始时间：当前时刻往前推 days_ago 天
    start_time = end_time - timedelta(days=days_ago)
    # 可选：如果你想保留开始时间为当天0点，可去掉下面注释；但为了涵盖整月，通常直接用 start_time
    # start_time = start_time.replace(hour=0, minute=0, second=0, microsecond=0)
    payload = {
        "BeginTime": start_time.strftime("%Y-%m-%d %H:%M:%S"),
        "EndTime": end_time.strftime("%Y-%m-%d %H:%M:%S"),
        "GGTYPE": ggtype,
        "KIND": kind,
        "pageNo": page_no,
        "pageSize": page_size,
        "timeType": "30",   # 注意：timeType 可能需要改为 30（近一个月）或根据接口文档调整
        "total": 0,
        "ts":int(time.time() * 1000),
        "AREACODE": "",
        "M_PROJECT_TYPE": "",
        "PROTYPE": "",
        "createTime": []
    }
    return payload

