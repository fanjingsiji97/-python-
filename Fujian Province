def fetch_trade_info(page_no: int = 1, page_size: int = 20, kind: str = "GCJS", ggtype: str = "1",
                     salt: str = "B3978D054A72A7002063637CCDF6B2E5",
                     session_cookie: Optional[str] = None) -> requests.Response:
    """
    发送 TradeInfo 请求，返回原始响应对象（未解密）
    需要提供有效的 ASP.NET_SessionId cookie（可从浏览器复制）
    """
    # 1. 构造参数
    payload = build_trade_payload(page_no, page_size, kind, ggtype)
    # 2. 生成签名
    sign = generate_portal_sign(payload, salt)
    # 3. 固定请求头
    headers = {
        "Accept": "application/json, text/plain, */*",
        "Accept-Language": "zh-CN,zh;q=0.9",
        "Connection": "keep-alive",
        "Content-Type": "application/json;charset=UTF-8",
        "Origin": "https://ggzyfw.fj.gov.cn",
        "Referer": "https://ggzyfw.fj.gov.cn/business/list/",
        "Sec-Fetch-Dest": "empty",
        "Sec-Fetch-Mode": "cors",
        "Sec-Fetch-Site": "same-origin",
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36",
        "portal-sign": sign,
        "sec-ch-ua": '"Google Chrome";v="147", "Not.A/Brand";v="8", "Chromium";v="147"',
        "sec-ch-ua-mobile": "?0",
        "sec-ch-ua-platform": '"Windows"'
    }
    cookies = {}
    if session_cookie:
        cookies["ASP.NET_SessionId"] = session_cookie

    url = "https://ggzyfw.fj.gov.cn/FwPortalApi/Trade/TradeInfo"
    response = requests.post(url, headers=headers, cookies=cookies, json=payload)
    return response
