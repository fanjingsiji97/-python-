def decrypt_data(encrypted_b64: str, key_str: str, iv_str: str) -> str:
    key = key_str.encode('utf-8')   # 直接 UTF-8 编码
    iv = iv_str.encode('utf-8')
    cipher = AES.new(key, AES.MODE_CBC, iv)
    encrypted_bytes = base64.b64decode(encrypted_b64)
    decrypted_padded = cipher.decrypt(encrypted_bytes)
    decrypted = unpad(decrypted_padded, AES.block_size)
    return decrypted.decode('utf-8')
# ---------------------------- 签名相关函数 ----------------------------
def clean_empty_params(params: Dict[str, Any]) -> Dict[str, Any]:
    """删除值为空字符串或 None 的字段，模拟前端 d(t) 中的预处理"""
    return {k: v for k, v in params.items() if v != "" and v is not None}

def sort_keys_ignore_case(keys: list) -> list:
    """模拟前端的 l 函数：不区分大小写的升序排序"""
    return sorted(keys, key=lambda x: x.upper())

def u(params: Dict[str, Any]) -> str:
    """
    模拟前端 u(t) 函数：
    1. 按键名不区分大小写排序
    2. 拼接 key + value
    3. 若 value 是 dict/list，先 JSON.stringify
    """
    cleaned = clean_empty_params(params)
    keys = sort_keys_ignore_case(list(cleaned.keys()))
    parts = []
    for k in keys:
        v = cleaned[k]
        if isinstance(v, (dict, list)):
            # ensure_ascii=False 保留中文，separators 去除空格
            parts.append(k + json.dumps(v, separators=(',', ':'), ensure_ascii=False))
        else:
            parts.append(k + str(v))
    return ''.join(parts)

def generate_portal_sign(params: Dict[str, Any], salt: str = "B3978D054A72A7002063637CCDF6B2E5") -> str:
    """
    生成 portal-sign
    公式：sign = MD5( salt + u(params) ).toLowerCase()
    """
    raw = salt + u(params)
    return hashlib.md5(raw.encode('utf-8')).hexdigest().lower()

